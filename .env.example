# Copy to .env and fill in real values. Never commit the real .env file.

SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Postgres connection for the Spring Boot backend.
# Use the Session Pooler connection string (Project Settings -> Database ->
# Connection Pooling -> Session mode), NOT the direct db.<ref>.supabase.co
# host — that one is IPv6-only and won't resolve on IPv4-only networks.
# Session mode (port 5432) supports prepared statements, required by
# Hibernate; the Transaction pooler (port 6543) does not.
DATABASE_URL=jdbc:postgresql://aws-1-<region>.pooler.supabase.com:5432/postgres
DATABASE_USER=postgres.<project-ref>
DATABASE_PASSWORD=

# Backend JWT signing secret (change in production)
JWT_SECRET=
